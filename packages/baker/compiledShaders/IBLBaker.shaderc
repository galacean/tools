{"name":"Galacean-IBL-baker","platformTarget":0,"subShaders":[{"name":"Default","tags":{},"passes":[{"name":"0","isUsePass":false,"tags":{},"renderStates":{"constantMap":{},"variableMap":{}},"vertexShaderInstructions":[[0,"attribute vec3 POSITION;\nattribute vec2 TEXCOORD_0;\n\nvarying vec2 v_uv;\n\n\n"],[2,"COMMON_INCLUDED",30],[0,"\n\n"],[7,"COMMON_INCLUDED"],[0,"\n\n"],[8,"PI","3.14159265359"],[0,"\n\n"],[8,"RECIPROCAL_PI","0.31830988618"],[0,"\n\n"],[8,"EPSILON","1e-6"],[0,"\n\n"],[8,"LOG2","1.442695"],[0,"\n\n"],[8,"HALF_MIN","6.103515625e-5"],[0,"\n\n"],[8,"HALF_EPS","4.8828125e-4"],[0,"\n\n"],[9,"saturate",["a"],"clamp( a, 0.0, 1.0 )"],[0,"\n\n"],[1,"GRAPHICS_API_WEBGL2",24],[0,"\n\n"],[9,"INVERSE_MAT",["mat"],"inverse(mat)"],[0,"\n\n"],[5,28],[0,"\n\n"],[9,"INVERSE_MAT",["mat"],"inverseMat(mat)"],[0,"\n\n"],[6],[0,"\n\n"],[6],[0,"\nvoid main() { \ngl_Position = vec4 ( POSITION.xzy , 1.0 ) ;\ngl_Position.y *= - 1.0 ;\nv_uv = TEXCOORD_0 ;\n }"]],"fragmentShaderInstructions":[[0,"varying vec2 v_uv;\n\n\n"],[2,"COMMON_INCLUDED",30],[0,"\n\n"],[7,"COMMON_INCLUDED"],[0,"\n\n"],[8,"PI","3.14159265359"],[0,"\n\n"],[8,"RECIPROCAL_PI","0.31830988618"],[0,"\n\n"],[8,"EPSILON","1e-6"],[0,"\n\n"],[8,"LOG2","1.442695"],[0,"\n\n"],[8,"HALF_MIN","6.103515625e-5"],[0,"\n\n"],[8,"HALF_EPS","4.8828125e-4"],[0,"\n\n"],[9,"saturate",["a"],"clamp( a, 0.0, 1.0 )"],[0,"\nfloat sRGBToLinear ( float value ) { float linearRGBLo = value / 12.92 ;\nfloat linearRGBHi = pow ( ( value + 0.055 ) / 1.055 , 2.4 ) ;\nfloat linearRGB = ( value <= 0.04045 ) ? linearRGBLo : linearRGBHi ;\nreturn linearRGB ; }\nvec4 sRGBToLinear ( vec4 value ) { return vec4 ( sRGBToLinear(value.r) , sRGBToLinear(value.g) , sRGBToLinear(value.b) , value.a ) ; }\n\n"],[1,"GRAPHICS_API_WEBGL2",24],[0,"\n\n"],[9,"INVERSE_MAT",["mat"],"inverse(mat)"],[0,"\n\n"],[5,28],[0,"\n\n"],[9,"INVERSE_MAT",["mat"],"inverseMat(mat)"],[0,"\n\n"],[6],[0,"\n\n"],[6],[0,"\nuniform samplerCube environmentMap;\nuniform float face;\nuniform float lodRoughness;\nuniform float u_textureSize;\nvec4 RGBEToLinear ( vec4 value ) { return vec4 ( value.rgb * exp2 ( value.a * 255.0 - 128.0 ) , 1.0 ) ; }\nconst uint SAMPLE_COUNT = 4096u;\nconst float MIN_ROUGHNESS = 0.002025;\nconst float HDR_LINEAR = 1024.0;\nconst float HDR_MAX = 16384.0;\nvec4 toLinear ( vec4 color ) { vec4 linear ;\n\n"],[3,"DECODE_MODE","==",0,34],[0," linear = color ; \n"],[5,40],[3,"DECODE_MODE","==",1,37],[0," linear = sRGBToLinear(color) ; \n"],[5,40],[3,"DECODE_MODE","==",2,40],[0," linear = RGBEToLinear(color) ; \n"],[6],[0,"\nreturn linear ; }\nvec3 compressHDR ( const in vec3 color ) { const vec3 rec709 = vec3 ( 0.2126 , 0.7152 , 0.0722 ) ;\nfloat luma = dot ( color , rec709 ) ;\nfloat s = 1.0 ;\nif ( luma > HDR_LINEAR ) { s = ( ( HDR_LINEAR * HDR_LINEAR - HDR_MAX * luma ) / ( ( 2.0 * HDR_LINEAR - HDR_MAX - luma ) * luma ) ) ; }\nreturn color * s ; }\nfloat D_GGX ( const in float a, const in float NoH ) { float f = ( a - 1.0 ) * ( ( a + 1.0 ) * ( NoH * NoH ) ) + 1.0 ;\nreturn ( a * a ) / ( PI * f * f ) ; }\nfloat radicalInverse_VdC ( uint bits ) { bits = ( bits << 16u ) | ( bits >> 16u ) ;\nbits = ( ( bits & 0x55555555u ) << 1u ) | ( ( bits & 0xAAAAAAAAu ) >> 1u ) ;\nbits = ( ( bits & 0x33333333u ) << 2u ) | ( ( bits & 0xCCCCCCCCu ) >> 2u ) ;\nbits = ( ( bits & 0x0F0F0F0Fu ) << 4u ) | ( ( bits & 0xF0F0F0F0u ) >> 4u ) ;\nbits = ( ( bits & 0x00FF00FFu ) << 8u ) | ( ( bits & 0xFF00FF00u ) >> 8u ) ;\nreturn float ( bits ) * 2.3283064365386963e-10 ; }\nvec2 hammersley ( uint i, uint N ) { return vec2 ( float ( i ) / float ( N ) , radicalInverse_VdC(i) ) ; }\nvec3 importanceSampleGGX ( vec2 Xi, vec3 N, float roughness ) { float a = roughness * roughness ;\nfloat phi = 2.0 * PI * Xi.x ;\nfloat cosTheta2 = ( 1.0 - Xi.y ) / ( 1.0 + ( a + 1.0 ) * ( ( a - 1.0 ) * Xi.y ) ) ;\nfloat cosTheta = sqrt ( cosTheta2 ) ;\nfloat sinTheta = sqrt ( 1.0 - cosTheta2 ) ;\nvec3 H ;\nH.x = cos ( phi ) * sinTheta ;\nH.y = sin ( phi ) * sinTheta ;\nH.z = cosTheta ;\nvec3 up = abs ( N.z ) < 0.999 ? vec3 ( 0.0 , 0.0 , 1.0 ) : vec3 ( 1.0 , 0.0 , 0.0 ) ;\nvec3 tangent = normalize ( cross ( up , N ) ) ;\nvec3 bitangent = cross ( N , tangent ) ;\nvec3 sampleVec = tangent * H.x + bitangent * H.y + N * H.z ;\nreturn normalize ( sampleVec ) ; }\nvec3 specular ( vec3 N ) { vec3 V = N ;\nfloat totalWeight = 0.0 ;\nvec3 prefilteredColor = vec3 ( 0.0 ) ;\nfloat omegaP = 4.0 * PI / ( 6.0 * u_textureSize * u_textureSize ) ;\nfor ( uint i = 0u ; i < SAMPLE_COUNT ; ++ i ) { vec2 Xi = hammersley(i, SAMPLE_COUNT) ;\nvec3 H = importanceSampleGGX(Xi, N, lodRoughness) ;\nvec3 L = normalize ( 2.0 * dot ( V , H ) * H - V ) ;\nfloat NdotL = max ( dot ( N , L ) , 0.0 ) ;\nif ( NdotL > 0.0 ) { float NoH = max ( dot ( N , H ) , 0.0 ) ;\nfloat pdf = D_GGX(max ( MIN_ROUGHNESS , lodRoughness ), NoH) * 0.25 ;\nfloat omegaS = 1.0 / ( float ( SAMPLE_COUNT ) * pdf ) ;\nfloat mipLevel = 1.0 + 0.5 * log2 ( omegaS / omegaP ) ;\nmipLevel = max ( mipLevel , 0.0 ) ;\nvec4 samplerColor = textureCubeLodEXT ( environmentMap , L , mipLevel ) ;\nvec3 linearColor = compressHDR(toLinear(samplerColor).rgb) ;\nprefilteredColor += linearColor * NdotL ;\ntotalWeight += NdotL ; } }\nprefilteredColor = prefilteredColor / totalWeight ;\nreturn prefilteredColor ; }\nvoid main() { float cx = v_uv.x * 2.0 - 1.0 ;\nfloat cy = v_uv.y * 2.0 - 1.0 ;\nvec3 dir = vec3 ( 0.0 ) ;\nif ( face == 0.0 ) { dir = vec3 ( 1.0 , cy , - cx ) ; } else if ( face == 1.0 ) { dir = vec3 ( - 1.0 , cy , cx ) ; } else if ( face == 2.0 ) { dir = vec3 ( cx , 1.0 , - cy ) ; } else if ( face == 3.0 ) { dir = vec3 ( cx , - 1.0 , cy ) ; } else if ( face == 4.0 ) { dir = vec3 ( cx , cy , 1.0 ) ; } else if ( face == 5.0 ) { dir = vec3 ( - cx , cy , - 1.0 ) ; }\ndir = normalize ( dir ) ;\nif ( lodRoughness == 0.0 ) { gl_FragColor = vec4 ( toLinear(textureCube ( environmentMap , dir )).rgb , 1.0 ) ; } else { vec3 integratedBRDF = specular(dir) ;\ngl_FragColor = vec4 ( integratedBRDF , 1.0 ) ; } }"]]}]}]}